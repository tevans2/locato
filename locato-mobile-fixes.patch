diff --git a/src/styles/responsive.css b/src/styles/responsive.css
index c388bcb..ab41719 100644
--- a/src/styles/responsive.css
+++ b/src/styles/responsive.css
@@ -288,3 +288,124 @@
     grid-template-columns: 1fr;
   }
 }
+
+/* Mobile hardening: keep controls reachable, avoid iOS safe-area overlap, and make dropdowns act like bottom sheets. */
+@media (max-width: 700px) {
+  html {
+    overflow-x: hidden;
+  }
+
+  body {
+    min-height: 100svh;
+    overflow-x: hidden;
+    overflow-y: auto;
+    overscroll-behavior-y: none;
+  }
+
+  .app-shell {
+    min-height: 100svh;
+    padding-top: max(56px, calc(12px + env(safe-area-inset-top)));
+    padding-right: max(10px, env(safe-area-inset-right));
+    padding-bottom: calc(18px + env(safe-area-inset-bottom));
+    padding-left: max(10px, env(safe-area-inset-left));
+  }
+
+  .game-screen {
+    gap: 10px;
+  }
+
+  .mode-description {
+    max-width: none;
+    text-align: left;
+  }
+
+  .play-layout,
+  .country-guess-layout {
+    grid-template-columns: minmax(0, 1fr);
+    grid-template-rows: auto;
+    gap: 10px;
+  }
+
+  .flag-card,
+  .answer-panel,
+  .world-map-panel {
+    border-radius: 6px;
+  }
+
+  .flag-card {
+    padding: 10px;
+  }
+
+  .flag-slot {
+    min-height: min(38svh, 320px);
+  }
+
+  .world-map-svg,
+  .world-globe-panel {
+    min-height: min(48svh, 420px);
+  }
+
+  .world-map-panel {
+    overscroll-behavior: contain;
+  }
+
+  .world-map-control-button {
+    min-width: 44px;
+    min-height: 44px;
+  }
+
+  .answer-panel {
+    padding: 10px;
+    gap: 8px;
+    overflow: visible;
+  }
+
+  .stats-panel,
+  .answer-panel .stats-panel {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .progress-card {
+    grid-column: 1 / -1;
+  }
+
+  .input-row {
+    grid-template-columns: 1fr;
+    gap: 8px;
+  }
+
+  .input-row button {
+    min-width: 0;
+  }
+
+  .category-dropdown-menu,
+  .game-mode-dropdown .category-dropdown-menu {
+    top: auto;
+    right: max(10px, env(safe-area-inset-right));
+    bottom: calc(10px + env(safe-area-inset-bottom));
+    left: max(10px, env(safe-area-inset-left));
+    width: auto;
+    max-height: min(70svh, 440px);
+  }
+}
+
+@media (max-width: 420px) {
+  .actions {
+    grid-template-columns: 1fr;
+  }
+
+  .brand-name {
+    display: none;
+  }
+}
+
+@media (max-width: 700px) and (max-height: 720px) {
+  .flag-slot {
+    min-height: 30svh;
+  }
+
+  .world-map-svg,
+  .world-globe-panel {
+    min-height: 42svh;
+  }
+}
