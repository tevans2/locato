# Client-side Google Maps Embed API key for the Street View Country mode.
# Enable Maps Embed API in Google Cloud, restrict this key by HTTP referrer, then restart Vite.
VITE_GOOGLE_MAPS_EMBED_API_KEY=

# Optional server-side key for OpenGuessr-style daily Street View pool generation.
# Enable Street View Static API for this key, and do NOT expose it in client code.
# Metadata lookups are used only by `npm run serve` and feed /api/streetview-country/round.
GOOGLE_MAPS_STREETVIEW_METADATA_API_KEY=

# Optional pool tuning. Defaults match the OpenGuessr-style setup: 50/day, capped at 500.
STREETVIEW_DAILY_GENERATE_COUNT=50
STREETVIEW_POOL_MAX_ENTRIES=500
STREETVIEW_REFRESH_HOURS=24
STREETVIEW_METADATA_RADIUS_METERS=1000
